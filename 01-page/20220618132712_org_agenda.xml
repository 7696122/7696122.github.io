  <item>
    <title>config</title>
    <link>http://lumiere.ens.fr/~guerry/20220618132712_org_agenda.html#orgfd731a2</link>
    <author>7696122 at gmail dot com (nil)</author>
    <guid isPermaLink="false">http://lumiere.ens.fr/~guerry/20220618132712_org_agenda.html#orgfd731a2</guid>
    <pubDate>Sun, 25 Dec 2022 06:41:00 +0900</pubDate>

    <description><![CDATA[<div class="org-src-container">
    <pre class="src src-elisp" id="orgfcf7736"><span style="color: #a020f0;">(use-package!</span> org-appear
    <span style="color: #483d8b;">:defer</span> t
    <span style="color: #483d8b;">:custom</span>
    (org-appear-autoemphasis t)
    (org-appear-autolinks t)
    (org-appear-autosubmarkers t)
    (org-appear-autoentities t)
    (org-appear-autokeywords t)
    (org-appear-inside-latex t)
    (org-appear-delay 0.0)
    (org-appear-trigger 'always)
    <span style="color: #483d8b;">:hook</span>
    (org-mode . org-appear-mode))
    </pre>
    </div>
    ]]></description>
  </item>

