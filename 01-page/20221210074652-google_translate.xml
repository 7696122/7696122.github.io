  <item>
    <title>config</title>
    <link>http://lumiere.ens.fr/~guerry/20221210074652-google_translate.html#org2f45c14</link>
    <author>7696122 at gmail dot com (nil)</author>
    <guid isPermaLink="false">http://lumiere.ens.fr/~guerry/20221210074652-google_translate.html#org2f45c14</guid>
    <pubDate>Sun, 25 Dec 2022 06:41:00 +0900</pubDate>

    <description><![CDATA[<div class="org-src-container">
    <pre class="src src-elisp" id="org57d69b4"><span style="color: #a020f0;">(use-package!</span> google-translate
    <span style="color: #483d8b;">:bind</span>
    (<span style="color: #8b2252;">"C-c t"</span> . google-translate-at-point)
    (<span style="color: #8b2252;">"C-c T"</span> . google-translate-query-translate)
    (<span style="color: #8b2252;">"C-c r"</span> . google-translate-at-point-reverse)
    (<span style="color: #8b2252;">"C-c R"</span> . google-translate-query-translate-reverse)
    <span style="color: #483d8b;">:custom</span>
    (google-translate-default-source-language <span style="color: #8b2252;">"auto"</span>)
    (google-translate-default-target-language nil)
    )
    </pre>
    </div>
    ]]></description>
